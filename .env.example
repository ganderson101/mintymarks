# MintyMarks — environment variables
# Copy this file to .env and fill in your values before deploying.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret key used to sign JWT auth tokens.
# Generate a strong random value with: openssl rand -hex 32
MINTYMARKS_SECRET=change-me-generate-a-strong-random-string

# Your public URL (used for CORS).
# Set this to your Cloudflare Tunnel domain, e.g. https://app.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com

# Cloudflare Tunnel token.
# Get this from: dash.cloudflare.com → Zero Trust → Networks → Tunnels → your tunnel → Configure
# It's the long string after --token in the install command Cloudflare shows you.
CLOUDFLARE_TUNNEL_TOKEN=paste-your-token-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the app will be served on for direct LAN access (default: 3000).
# Internet access goes via Cloudflare tunnel (no port forwarding needed).
MINTYMARKS_PORT=3000

# Set to "false" only for local development over plain HTTP.
# In production (Cloudflare Tunnel = HTTPS) leave this unset or set to "true".
# COOKIE_SECURE=false

# Set ENVIRONMENT=production in production to guard dev-only endpoints.
ENVIRONMENT=production

# ── Email / magic-link ────────────────────────────────────────────────────────

# Leave unset (or set to 'console') for local dev — magic links are printed to stdout.
# Set to 'sendgrid' or 'smtp' in production.
# EMAIL_PROVIDER=sendgrid

# The "From" address for magic-link emails.
# EMAIL_FROM=noreply@yourdomain.com

# Frontend base URL used when building the magic-link URL sent in emails.
# Defaults to http://localhost:5173 for local dev.
# FRONTEND_URL=https://app.yourdomain.com

# SendGrid: provide SENDGRID_API_KEY when EMAIL_PROVIDER=sendgrid.
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# Generic SMTP: provide these when EMAIL_PROVIDER=smtp.
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
