# MindArc — environment variables
# Copy this file to .env and fill in your values before deploying.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret key used to sign JWT auth tokens.
# Generate a strong random value with: openssl rand -hex 32
MINDARC_SECRET=change-me-generate-a-strong-random-string

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the app will be served on (default: 3000).
# Access the app at http://<NAS-IP>:3000
MINDARC_PORT=3000

# Allowed CORS origins for the API (comma-separated).
# If you access the app through a Synology reverse proxy on port 80/443,
# set this to your NAS hostname or IP, e.g. http://192.168.1.100 or https://mindarc.local
# Leave blank to default to http://localhost (same-origin through nginx, usually fine).
ALLOWED_ORIGINS=http://localhost
