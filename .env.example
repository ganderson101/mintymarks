# MindArc — environment variables
# Copy this file to .env and fill in your values before deploying.

# ── Required ──────────────────────────────────────────────────────────────────

# Secret key used to sign JWT auth tokens.
# Generate a strong random value with: openssl rand -hex 32
MINDARC_SECRET=change-me-generate-a-strong-random-string

# Your public URL (used for CORS).
# Set this to your Cloudflare Tunnel domain, e.g. https://app.yourdomain.com
ALLOWED_ORIGINS=https://app.yourdomain.com

# Cloudflare Tunnel token.
# Get this from: dash.cloudflare.com → Zero Trust → Networks → Tunnels → your tunnel → Configure
# It's the long string after --token in the install command Cloudflare shows you.
CLOUDFLARE_TUNNEL_TOKEN=paste-your-token-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the app will be served on for direct LAN access (default: 3000).
# Internet access goes via Cloudflare tunnel (no port forwarding needed).
MINDARC_PORT=3000

# Set to "false" only for local development over plain HTTP.
# In production (Cloudflare Tunnel = HTTPS) leave this unset or set to "true".
# COOKIE_SECURE=false
